# Copy to .env and fill in once the accounts exist (post-approval).
# All are build-time PUBLIC_ vars (static site — no server secrets here).

# Waitlist ESP endpoint that accepts POST { email }. Recommended: a Resend /
# MailerLite form endpoint or a thin Cloudflare/Vercel function in front of them.
# Leave empty to run the waitlist form in local "preview mode".
PUBLIC_ESP_ENDPOINT=
PUBLIC_ESP_FORM_ID=

# Privacy-friendly, cookieless analytics (e.g. Plausible or Cloudflare Web Analytics).
PUBLIC_ANALYTICS_DOMAIN=
PUBLIC_ANALYTICS_SRC=
