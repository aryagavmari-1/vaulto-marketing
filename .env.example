# Copy to .env and fill in once the accounts exist (post-approval).
# All are build-time PUBLIC_ vars (static site — no server secrets here).

# Waitlist ESP endpoint that accepts POST { email }. Recommended: a Resend /
# MailerLite form endpoint or a thin Cloudflare/Vercel function in front of them.
# Leave empty to run the waitlist form in local "preview mode".
PUBLIC_ESP_ENDPOINT=
PUBLIC_ESP_FORM_ID=

# Privacy-friendly, cookieless analytics (Plausible/Umami-compatible alternative).
PUBLIC_ANALYTICS_DOMAIN=
PUBLIC_ANALYTICS_SRC=

# Cloudflare Web Analytics beacon token (PRIMARY analytics — $0, cookieless,
# no consent banner). Cloudflare dashboard → Web Analytics → site → snippet token.
PUBLIC_CF_BEACON_TOKEN=

# Google Search Console HTML-tag verification content (search KPIs source).
PUBLIC_GSC_VERIFICATION=

# --- KPI puller, server-side only — set as CI secrets, never PUBLIC_ / committed ---
# CF_API_TOKEN=
# CF_ACCOUNT_TAG=
# GSC_SERVICE_ACCOUNT_JSON=
