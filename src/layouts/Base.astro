---
import '../styles/global.css';
import { BRAND } from '../config/brand';
import { DEFAULT_LOCALE, HREFLANG, dirFor, localizedPath, type Locale } from '../config/i18n';
import type { FaqItem, Crumb } from '../config/structured-data';
import Seo from '../components/Seo.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

type Alternate = { hreflang: string; href: string };
type SwitcherOption = { value: string; label: string; selected: boolean };
interface Props {
  title?: string;
  description?: string;
  path?: string;
  locale?: Locale;        // page locale (default `en`); drives <html lang> + canonical
  type?: 'website' | 'article';
  image?: string;
  publishedTime?: string;
  noindex?: boolean;
  faq?: FaqItem[];        // emits FAQPage structured data (ARY-399 §2d)
  breadcrumbs?: Crumb[];  // emits BreadcrumbList structured data (ARY-399 §2d)
  // Blog i18n (ARY-523): translated-slug articles don't share a path across
  // locales, so the page supplies its own canonical URL, hreflang alternates,
  // and language-switcher targets rather than deriving them by prefix.
  canonicalPath?: string; // explicit (already-localized) path for <link canonical>
  alternates?: Alternate[];
  switcher?: SwitcherOption[];
}
const {
  title, description = BRAND.description, path = '/', locale = DEFAULT_LOCALE,
  type = 'website', image, publishedTime, noindex = false, faq, breadcrumbs,
  canonicalPath, alternates, switcher,
} = Astro.props;
const fullTitle = title ? `${title} · ${BRAND.name}` : `${BRAND.name} — ${BRAND.tagline}`;
// Canonical is the locale-prefixed URL (English un-prefixed) so each localized
// page is self-canonical and hreflang pairs resolve correctly. Blog pages pass
// `canonicalPath` (already localized) since their slug varies per locale.
const canonical = new URL(canonicalPath ?? localizedPath(path, locale), BRAND.url).href;
---
<!doctype html>
<html lang={HREFLANG[locale]} dir={dirFor(locale)}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <Seo
      title={fullTitle}
      description={description}
      canonical={canonical}
      path={path}
      locale={locale}
      type={type}
      image={image}
      publishedTime={publishedTime}
      noindex={noindex}
      faq={faq}
      breadcrumbs={breadcrumbs}
      alternates={alternates}
    />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <Header path={path} locale={locale} switcher={switcher} />
    <main id="main">
      <slot />
    </main>
    <Footer locale={locale} />

    <!-- Analytics (ARY-25 spec). Cookieless, no PII in event props. Sink is
         Plausible/Umami when configured; otherwise track() is a safe no-op. -->
    <script is:inline>
      (() => {
        window.track = (name, props) => {
          try { window.plausible && window.plausible(name, { props: props || {} }); } catch (e) {}
        };
        // page_view is emitted natively by the analytics script; here we wire
        // the marketing CTAs declared via data attributes.
        document.addEventListener('click', (e) => {
          const cta = e.target.closest('[data-cta]');
          if (cta) window.track('cta_click', { cta_id: cta.getAttribute('data-cta'), path: location.pathname });
          const out = e.target.closest('[data-outbound]');
          if (out) window.track('outbound_click', { destination: out.getAttribute('data-outbound') });
        });
      })();
    </script>
  </body>
</html>
