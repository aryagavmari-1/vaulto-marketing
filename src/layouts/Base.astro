---
import '../styles/global.css';
import { BRAND } from '../config/brand';
import { DEFAULT_LOCALE } from '../config/i18n';
import Seo from '../components/Seo.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  path?: string;
  type?: 'website' | 'article';
  image?: string;
  publishedTime?: string;
  noindex?: boolean;
}
const {
  title, description = BRAND.description, path = '/',
  type = 'website', image, publishedTime, noindex = false,
} = Astro.props;
const fullTitle = title ? `${title} · ${BRAND.name}` : `${BRAND.name} — ${BRAND.tagline}`;
const canonical = new URL(path, BRAND.url).href;
---
<!doctype html>
<html lang={DEFAULT_LOCALE}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <Seo
      title={fullTitle}
      description={description}
      canonical={canonical}
      path={path}
      type={type}
      image={image}
      publishedTime={publishedTime}
      noindex={noindex}
    />
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />

    <!-- Analytics (ARY-25 spec). Cookieless, no PII in event props. Sink is
         Plausible/Umami when configured; otherwise track() is a safe no-op. -->
    <script is:inline>
      (() => {
        window.track = (name, props) => {
          try { window.plausible && window.plausible(name, { props: props || {} }); } catch (e) {}
        };
        // page_view is emitted natively by the analytics script; here we wire
        // the marketing CTAs declared via data attributes.
        document.addEventListener('click', (e) => {
          const cta = e.target.closest('[data-cta]');
          if (cta) window.track('cta_click', { cta_id: cta.getAttribute('data-cta'), path: location.pathname });
          const out = e.target.closest('[data-outbound]');
          if (out) window.track('outbound_click', { destination: out.getAttribute('data-outbound') });
        });
      })();
    </script>
  </body>
</html>
