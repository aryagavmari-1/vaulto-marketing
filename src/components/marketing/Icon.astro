---
/**
 * Vaulto custom icon set (ARY-451).
 *
 * One cohesive line set drawn on a 24px grid, 1.7 stroke, round caps/joins,
 * `currentColor` — so an icon inherits the colour of its chip (olive `--primary`
 * in neutral chips, `--success` on the Security page, white on the olive CTA).
 * This replaces every raw emoji previously used as UI iconography across Home,
 * How-it-works, Features, Security and Planning.
 *
 * Accessibility: decorative by default (`aria-hidden`). Pass `label` to mark an
 * icon as meaningful — it then renders `role="img"` + `aria-label` instead.
 */
interface Props {
  name: string;
  size?: number;
  label?: string;
  class?: string;
  strokeWidth?: number;
}
const { name, size = 24, label, class: cls = '', strokeWidth = 1.7 } = Astro.props;

// Inner markup per icon (no fill; stroke = currentColor via the wrapper <svg>).
const ICONS: Record<string, string> = {
  // — Core / Home —
  lock: '<rect x="5" y="11" width="14" height="9" rx="2"/><path d="M8 11V8a4 4 0 0 1 8 0v3"/><path d="M12 14.7v2.6"/>',
  home: '<path d="M4 11.4 12 4l8 7.4"/><path d="M6 10.2V20h12v-9.8"/><path d="M10 20v-5h4v5"/>',
  document: '<path d="M7 3h7l4 4v13a1 1 0 0 1-1 1H7a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1Z"/><path d="M14 3v4h4"/><path d="M9.5 12.5h5M9.5 16h5"/>',
  chart: '<path d="M4 4v15a1 1 0 0 0 1 1h15"/><path d="M8 15l3.2-3.4 2.8 2L19 7.5"/><path d="M19 11V7.5h-3.5"/>',
  folders: '<path d="M4 8a2 2 0 0 1 2-2h2.6a1 1 0 0 1 .8.4L11 8h7a2 2 0 0 1 2 2v7a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2Z"/>',
  shield: '<path d="M12 3 5 5.8v5c0 4.6 3 7.7 7 9.2 4-1.5 7-4.6 7-9.2v-5Z"/>',
  compass: '<circle cx="12" cy="12" r="8.5"/><path d="M15.7 8.3 13 13l-4.7 2.7L11 11Z"/>',
  // — Security —
  globe: '<circle cx="12" cy="12" r="8.5"/><path d="M3.5 12h17"/><path d="M12 3.5c2.4 2.5 2.4 14.5 0 17M12 3.5c-2.4 2.5-2.4 14.5 0 17"/>',
  database: '<ellipse cx="12" cy="6" rx="7" ry="2.8"/><path d="M5 6v12c0 1.6 3.1 2.8 7 2.8s7-1.2 7-2.8V6"/><path d="M5 12c0 1.6 3.1 2.8 7 2.8s7-1.2 7-2.8"/>',
  key: '<circle cx="8" cy="15" r="3.6"/><path d="M10.6 12.4 19 4M16 7l2 2M14 9l2 2"/>',
  clock: '<circle cx="12" cy="12" r="8.5"/><path d="M12 7.5V12l3.2 2"/>',
  shieldCheck: '<path d="M12 3 5 5.8v5c0 4.6 3 7.7 7 9.2 4-1.5 7-4.6 7-9.2v-5Z"/><path d="M9 12l2.2 2.2L15.5 10"/>',
  user: '<circle cx="12" cy="8" r="3.6"/><path d="M5 20c0-3.6 3.1-6 7-6s7 2.4 7 6"/>',
  ban: '<circle cx="12" cy="12" r="8.5"/><path d="M6.4 6.4 17.6 17.6"/>',
  eyeOff: '<path d="M3 12s3.5-6.2 9-6.2c1.6 0 3 .4 4.3 1.1M20.5 9.6A19 19 0 0 1 21 12s-3.5 6.2-9 6.2c-1.4 0-2.7-.3-3.8-.8"/><path d="M9.6 9.7A3 3 0 0 0 12 15a3 3 0 0 0 2.3-1.1"/><path d="M4 4l16 16"/>',
  sliders: '<path d="M4 8h9M17 8h3M4 16h3M11 16h9"/><circle cx="15" cy="8" r="2.2"/><circle cx="9" cy="16" r="2.2"/>',
  // — Features / How-it-works —
  camera: '<rect x="3" y="7" width="18" height="13" rx="2.4"/><path d="M8.2 7 9.6 4.6h4.8L15.8 7"/><circle cx="12" cy="13.4" r="3.3"/>',
  layers: '<path d="M12 3 3.5 7.5 12 12l8.5-4.5Z"/><path d="M3.5 12.5 12 17l8.5-4.5"/>',
  download: '<path d="M12 4v10M8.2 10.6 12 14.5l3.8-3.9"/><path d="M5 19.5h14"/>',
  // — UI glyphs —
  chevron: '<path d="M6 9.5 12 15l6-5.5"/>',
  check: '<path d="M5 12.6 9.4 17 19 7.2"/>',
};

const inner = ICONS[name] ?? ICONS.check;
const decorative = !label;
---
<svg
  class={`vico ${cls}`}
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width={strokeWidth}
  stroke-linecap="round"
  stroke-linejoin="round"
  role={decorative ? undefined : 'img'}
  aria-hidden={decorative ? 'true' : undefined}
  aria-label={label}
  set:html={inner}
/>
