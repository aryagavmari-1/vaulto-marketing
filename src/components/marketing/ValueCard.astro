---
/**
 * §3.4 ValueCard — white card, muted icon chip, heading + body.
 * `icon` is a name in the custom Icon set (ARY-451), not a raw emoji.
 */
import Icon from './Icon.astro';
interface Props { icon: string; title: string; }
const { icon, title } = Astro.props;
---
<div class="vcard card">
  <div class="ico" aria-hidden="true"><Icon name={icon} size={24} /></div>
  <h3 class="t-heading">{title}</h3>
  <p class="t-body"><slot /></p>
</div>
