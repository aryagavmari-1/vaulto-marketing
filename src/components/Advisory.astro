---
import { ADVISORY } from '../config/content';
---
<section class="section advisory" id="advisory">
  <div class="container">
    <div style="max-width:640px;">
      <span class="eyebrow">{ADVISORY.eyebrow}</span>
      <h2>{ADVISORY.title}</h2>
      <p>{ADVISORY.body}</p>
    </div>
    <div class="chips">
      {ADVISORY.channels.map((c) => <span class="chip">{c}</span>)}
    </div>
    <div style="margin:18px 0 6px;">
      <a class="btn btn-primary" href="#waitlist" data-cta="advisory_waitlist" style="background:var(--accent);color:#2a1c08;">{ADVISORY.cta}</a>
    </div>
    <p class="footnote">{ADVISORY.footnote}</p>
  </div>
</section>
