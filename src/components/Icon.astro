---
// Minimal inline-SVG icon set (stroke, currentColor) — no icon-font dependency.
interface Props { name: string; size?: number; }
const { name, size = 22 } = Astro.props;
const paths: Record<string, string> = {
  layers: 'M12 2 2 7l10 5 10-5-10-5Z M2 17l10 5 10-5 M2 12l10 5 10-5',
  camera: 'M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z M12 17a4 4 0 1 0 0-8 4 4 0 0 0 0 8Z',
  compass: 'M12 22a10 10 0 1 0 0-20 10 10 0 0 0 0 20Z M16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76Z',
  check: 'M20 6 9 17l-5-5',
  shield: 'M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z',
};
const d = paths[name] ?? paths.check;
---
<svg width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor"
     stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
  {d.split(' M').map((seg, i) => <path d={(i === 0 ? seg : 'M' + seg)} />)}
</svg>
