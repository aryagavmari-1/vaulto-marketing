---
import { BRAND } from '../config/brand';
---
<footer class="site-footer">
  <div class="container">
    <div class="footer-grid">
      <div style="max-width:320px;">
        <div class="brandmark" style="color:#fff;margin-bottom:10px;">
          <span class="brand-dot" aria-hidden="true"></span>{BRAND.name}
        </div>
        <p style="color:#8aa19d;font-size:0.92rem;">{BRAND.tagline}</p>
      </div>
      <nav class="footer-links" aria-label="Footer">
        <a href="/#how">How it works</a>
        <a href="/#advisory">Advisory</a>
        <a href="/blog/">Blog</a>
        <a href="/security/">Security</a>
        <a href="/privacy/">Privacy</a>
        <a href={`mailto:${BRAND.email.hello}`}>Contact</a>
      </nav>
    </div>
    <div class="footer-bottom">
      <p style="color:#8aa19d;margin:0;">
        © <span>{BRAND.name}</span>. Educational guidance only — not legal, tax, or financial advice.
        {BRAND.provisional && " · Brand & domain provisional, pending board approval."}
      </p>
    </div>
  </div>
</footer>
