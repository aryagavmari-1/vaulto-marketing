---
/**
 * Global footer (ARY-404 §2). Muted band: wordmark + Security · Privacy ·
 * Sign in →. "Sign in →" is the hand-off to the live app.
 */
import { BRAND } from '../config/brand';
---
<footer class="foot">
  <div class="wrap">
    <a class="brand" href="/" aria-label={`${BRAND.name} home`}>
      <span class="logo" aria-hidden="true"></span>{BRAND.name}
    </a>
    <nav class="foot-links" aria-label="Footer">
      <span class="muted">© {BRAND.name}</span>
      <a href="/security/">Security</a>
      <a href="/privacy/">Privacy</a>
      <a href={BRAND.app} data-outbound="app">Sign in →</a>
    </nav>
  </div>
</footer>
