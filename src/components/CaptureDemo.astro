---
import { CAPTURE_DEMO } from '../config/content';
---
<section class="section trust-strip" id="how">
  <div class="container">
    <div class="center" style="margin-bottom:8px;">
      <h2>{CAPTURE_DEMO.title}</h2>
      <p class="lead">{CAPTURE_DEMO.body}</p>
    </div>
    <div class="steps">
      {CAPTURE_DEMO.steps.map((s) => (
        <div class="card step">
          <div class="n">{s.n}</div>
          <div class="lbl">{s.label}</div>
          <p style="margin:0;">{s.text}</p>
        </div>
      ))}
    </div>
  </div>
</section>
