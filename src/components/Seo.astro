---
/**
 * Centralised SEO + structured-data + analytics head block (ARY-401 / ARY-403).
 * Base.astro renders exactly one <Seo /> per page. Adding meta/JSON-LD here
 * propagates everywhere, so content sub-agents get correct SEO for free.
 *
 * Structured data (CMO ARY-399 §2d): Organization + WebSite site-wide;
 * SoftwareApplication auto-attached to the home page; BlogPosting on articles;
 * FAQPage and BreadcrumbList opt-in via props (pass `faq` / `breadcrumbs` from
 * <Base/>). hreflang + the localized sitemap are driven from config/i18n.ts.
 */
import { BRAND, ANALYTICS } from '../config/brand';
import { alternatesFor, DEFAULT_LOCALE, HREFLANG, type Locale } from '../config/i18n';
import {
  softwareApplication,
  faqPage,
  breadcrumbList,
  orgId,
  websiteId,
  type FaqItem,
  type Crumb,
} from '../config/structured-data';

interface Props {
  title: string;          // fully composed <title> text
  description: string;
  canonical: string;
  path: string;
  locale?: Locale;        // page locale — drives JSON-LD inLanguage + og:locale
  type?: 'website' | 'article';
  image?: string;         // path or absolute URL; defaults to /og.png
  publishedTime?: string; // ISO 8601, articles only
  noindex?: boolean;
  faq?: FaqItem[];        // emits FAQPage JSON-LD (ARY-399 §2d)
  breadcrumbs?: Crumb[];  // emits BreadcrumbList JSON-LD (ARY-399 §2d)
  // Explicit hreflang alternates (ARY-523). Blog articles use translated slugs
  // that don't share a path across locales, so they pass their own set rather
  // than letting `alternatesFor(path)` derive them by locale prefix.
  alternates?: { hreflang: string; href: string }[];
}
const {
  title, description, canonical, path, locale = DEFAULT_LOCALE,
  type = 'website', image, publishedTime, noindex = false,
  faq, breadcrumbs, alternates: alternatesProp,
} = Astro.props;

// Default share card MUST be a PNG: Facebook/Twitter/LinkedIn/iMessage do not
// render SVG OG images (ARY-449 P0 #1). `public/og.png` is baked from og.svg by
// scripts/build-og.mjs (wired into prebuild). og.svg stays the editable source.
const ogImage = new URL(image ?? '/og.png', BRAND.url).href;
const alternates = alternatesProp ?? alternatesFor(path, BRAND.url);
// Twitter @handle for card attribution (ARY-449 P1 #7). Empty until the profile
// exists (ARY-27) — when populated, twitter:site lights up automatically.
const twitterSite = BRAND.social.xHandle || '';
const lang = HREFLANG[locale];

// Privacy-friendly, cookieless analytics. Cloudflare Web Analytics is the
// primary ($0, unlimited, no consent banner). The Plausible/Umami-compatible
// hook from ARY-25 is kept as a drop-in alternative. Both are env-gated, so the
// site builds and previews with neither configured.
const cfToken = import.meta.env.PUBLIC_CF_BEACON_TOKEN ?? '';
const gscVerify = import.meta.env.PUBLIC_GSC_VERIFICATION ?? '';

// schema.org graph. Organization + WebSite are site-wide; SoftwareApplication is
// the home page; BlogPosting on articles; FAQPage/BreadcrumbList are opt-in.
const org = {
  '@type': 'Organization',
  '@id': orgId(BRAND.url),
  name: BRAND.name,
  url: BRAND.url,
  logo: new URL('/favicon.svg', BRAND.url).href,
  description: BRAND.description,
  ...(BRAND.social.linkedin || BRAND.social.x
    ? { sameAs: [BRAND.social.linkedin, BRAND.social.x].filter(Boolean) }
    : {}),
};
const website = {
  '@type': 'WebSite',
  '@id': websiteId(BRAND.url),
  url: BRAND.url,
  name: BRAND.name,
  publisher: { '@id': orgId(BRAND.url) },
  inLanguage: lang,
};
const graph: Record<string, unknown>[] = [org, website];

// SoftwareApplication (FinanceApplication, free offer) on the home page only.
const isHome = path === '/' || path === '';
if (isHome) {
  graph.push(softwareApplication(BRAND.url, BRAND.name, BRAND.description));
}
if (faq && faq.length) {
  graph.push(faqPage(faq));
}
if (breadcrumbs && breadcrumbs.length) {
  graph.push(breadcrumbList(breadcrumbs));
}
if (type === 'article') {
  graph.push({
    '@type': 'BlogPosting',
    headline: title,
    description,
    url: canonical,
    image: ogImage,
    ...(publishedTime ? { datePublished: publishedTime } : {}),
    author: { '@id': orgId(BRAND.url) },
    publisher: { '@id': orgId(BRAND.url) },
    inLanguage: lang,
    mainEntityOfPage: canonical,
  });
}
const jsonLd = JSON.stringify({ '@context': 'https://schema.org', '@graph': graph });
---
<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonical} />
{noindex && <meta name="robots" content="noindex, nofollow" />}
{gscVerify && <meta name="google-site-verification" content={gscVerify} />}

{alternates.map((a) => <link rel="alternate" hreflang={a.hreflang} href={a.href} />)}

<meta property="og:type" content={type} />
<meta property="og:site_name" content={BRAND.name} />
<meta property="og:locale" content={lang} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={ogImage} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content={`${BRAND.name} — ${BRAND.tagline}`} />
{publishedTime && <meta property="article:published_time" content={publishedTime} />}
<meta name="twitter:card" content="summary_large_image" />
{twitterSite && <meta name="twitter:site" content={twitterSite} />}
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage} />
<meta name="twitter:image:alt" content={`${BRAND.name} — ${BRAND.tagline}`} />

<script type="application/ld+json" set:html={jsonLd} />

{/* Cloudflare Web Analytics — primary, $0, cookieless. */}
{cfToken && (
  <script defer src="https://static.cloudflareinsights.com/beacon.min.js"
    data-cf-beacon={`{"token": "${cfToken}"}`}></script>
)}
{/* Plausible/Umami-compatible alternative (ARY-25). */}
{ANALYTICS.src && ANALYTICS.domain && (
  <script defer data-domain={ANALYTICS.domain} src={ANALYTICS.src}></script>
)}
