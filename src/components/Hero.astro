---
import { HERO } from '../config/content';
---
<section class="hero">
  <div class="container section hero-grid">
    <div>
      <span class="eyebrow">{HERO.eyebrow}</span>
      <h1>{HERO.title}</h1>
      <p class="lead">{HERO.subtitle}</p>
      <div class="cta-row">
        <a class="btn btn-primary" href="#waitlist">{HERO.primaryCta}</a>
        <a class="btn btn-ghost" href="#how">{HERO.secondaryCta}</a>
      </div>
      <p class="reassurance">{HERO.reassurance}</p>
    </div>

    <div aria-hidden="true">
      <div class="vault-card">
        <div class="vault-top">
          <div>
            <div class="muted" style="font-size:0.82rem;">Household net worth</div>
            <div class="vault-net">£842,500</div>
          </div>
          <span class="tag-up">▲ Vault strength 78</span>
        </div>
        <div class="vault-row">
          <div class="vi"><span class="vault-ic">H</span><span>Home &amp; property</span></div>
          <span class="vault-amt">£610,000</span>
        </div>
        <div class="vault-row">
          <div class="vi"><span class="vault-ic">£</span><span>Accounts &amp; savings</span></div>
          <span class="vault-amt">£118,200</span>
        </div>
        <div class="vault-row">
          <div class="vi"><span class="vault-ic">◆</span><span>Valuables &amp; collections</span></div>
          <span class="vault-amt">£64,300</span>
        </div>
        <div class="vault-row">
          <div class="vi"><span class="vault-ic">▤</span><span>Documents on file</span></div>
          <span class="vault-amt">23</span>
        </div>
      </div>
    </div>
  </div>
</section>
