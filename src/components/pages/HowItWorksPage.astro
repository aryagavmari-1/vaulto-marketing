---
/**
 * How it works page body, locale-aware (ARY-427). All copy comes from
 * `content/how-it-works/<locale>.json` via `getContent`; emoji/glyphs, step
 * numbers, and the security link href stay here. English is the source +
 * fallback.
 */
import Base from '../../layouts/Base.astro';
import { BRAND } from '../../config/brand';
import { DEFAULT_LOCALE, type Locale } from '../../config/i18n';
import { getContent } from '../../i18n/content';
import Eyebrow from '../marketing/Eyebrow.astro';
import FinalCta from '../marketing/FinalCta.astro';
import ProductShot from '../marketing/ProductShot.astro';

interface Props { locale?: Locale; }
const { locale = DEFAULT_LOCALE } = Astro.props;
const c = getContent<any>('how-it-works', locale);

const crumbs = [
  { name: c.crumbs.home, url: `${BRAND.url}/` },
  { name: c.crumbs.howItWorks, url: `${BRAND.url}/how-it-works/` },
];
// Device-framed app scene per step (ARY-451). Labels double as screenshot alt.
const stepShots: { scene: 'capture' | 'inventory' | 'overview'; label: string }[] = [
  { scene: 'capture', label: 'Vaulto capture screen: photograph a document and the app reads it and suggests the details to confirm.' },
  { scene: 'inventory', label: 'Vaulto inventory screen: assets organised into a clean, scannable list with a secured badge on each.' },
  { scene: 'overview', label: 'Vaulto overview screen: the whole picture of what your family owns, with total value and a trend chart.' },
];
// Plans beats (ARY-507). A glyph per beat — Plans cover sensitive areas, so no
// app screenshots here; calm signpost/conversation/plan icons instead.
const planGlyphs = ['🧭', '💬', '📋'];
---
<Base
  title={c.meta.title}
  description={c.meta.description}
  path="/how-it-works/"
  locale={locale}
  breadcrumbs={crumbs}
>
  <section class="s-hero">
    <div class="wrap">
      <Eyebrow tone="success">{c.hero.eyebrow}</Eyebrow>
      <h1 class="t-display">{c.hero.heading}</h1>
      <p class="intro t-bodyL">{c.hero.intro}</p>
    </div>
  </section>

  <section>
    <div class="wrap">
      <div class="steps-rows">
        {c.steps.map((s: any, i: number) => (
          <>
            <div class:list={['step-row', i % 2 === 1 && 'reverse']}>
              <div class="step-body">
                <div class="num" aria-hidden="true">{i + 1}</div>
                <h2 class="t-title">{s.title}</h2>
                <p class="t-bodyL">{s.body}</p>
                <p class="detail">{s.detail}</p>
              </div>
              <div class="step-visual step-visual--shot">
                <ProductShot frame="phone" scene={stepShots[i].scene} label={stepShots[i].label} />
              </div>
            </div>
            {i < c.steps.length - 1 && <div class="connector" aria-hidden="true"></div>}
          </>
        ))}
      </div>
    </div>
  </section>

  <section class="s-plans">
    <div class="wrap">
      <div class="plans-intro">
        <Eyebrow tone="info">{c.plans.eyebrow}</Eyebrow>
        <h2 class="t-title">{c.plans.heading}</h2>
        <p class="intro t-bodyL">{c.plans.intro}</p>
      </div>
      <div class="steps-rows">
        {c.plans.beats.map((b: any, i: number) => (
          <>
            <div class:list={['step-row', i % 2 === 1 && 'reverse']}>
              <div class="step-body">
                <h2 class="t-title">{b.title}</h2>
                <p class="t-bodyL">{b.body}</p>
                <p class="detail">{b.detail}</p>
              </div>
              <div class="step-visual" aria-hidden="true"><span class="glyph">{planGlyphs[i]}</span></div>
            </div>
            {i < c.plans.beats.length - 1 && <div class="connector" aria-hidden="true"></div>}
          </>
        ))}
      </div>
      <p class="plans-honesty t-body">{c.plans.honesty}</p>
      <p class="center" style="margin-top:32px;">
        <a href="/security/" data-cta="how_security">{c.securityLink}</a>
      </p>
    </div>
  </section>

  <FinalCta title={c.finalCta.title} body={c.finalCta.body} ctaId="how_final" />
</Base>
