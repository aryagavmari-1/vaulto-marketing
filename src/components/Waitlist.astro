---
import { WAITLIST } from '../config/content';
import { ESP } from '../config/brand';
const placement = 'closing';
---
<section class="section" id="waitlist">
  <div class="container">
    <div class="waitlist">
      <h2>{WAITLIST.title}</h2>
      <p>{WAITLIST.body}</p>
      <form class="wl-form" id="wl-form" data-endpoint={ESP.endpoint} data-formid={ESP.formId} data-placement={placement} novalidate>
        <label class="visually-hidden" for="wl-email">Email address</label>
        <input id="wl-email" name="email" type="email" required autocomplete="email" placeholder={WAITLIST.placeholder} />
        <button class="btn btn-primary" type="submit">{WAITLIST.cta}</button>
      </form>
      <p class="wl-msg" id="wl-msg" role="status" aria-live="polite"></p>
      <p class="wl-note">{WAITLIST.reassurance}</p>
      {!ESP.endpoint && (
        <p class="wl-note">Preview mode — no ESP endpoint configured yet. Set <code>PUBLIC_ESP_ENDPOINT</code> to capture live signups.</p>
      )}
    </div>
  </div>
</section>

<script is:inline define:vars={{ successMsg: WAITLIST.success }}>
  (() => {
    const form = document.getElementById('wl-form');
    if (!form) return;
    const msg = document.getElementById('wl-msg');
    const input = document.getElementById('wl-email');
    const placement = form.dataset.placement || 'closing';
    const track = (n, p) => { try { window.track && window.track(n, p); } catch (e) {} };

    // waitlist_view when the form scrolls into view (once).
    if ('IntersectionObserver' in window) {
      const io = new IntersectionObserver((entries) => {
        entries.forEach((en) => {
          if (en.isIntersecting) { track('waitlist_view', { placement }); io.disconnect(); }
        });
      }, { threshold: 0.4 });
      io.observe(form);
    } else {
      track('waitlist_view', { placement });
    }

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const email = (input.value || '').trim();
      if (!email || !/^[^@\s]+@[^@\s]+\.[^@\s]+$/.test(email)) {
        msg.textContent = 'Please enter a valid email address.';
        msg.style.color = '#ffd9a8';
        return;
      }
      const endpoint = form.dataset.endpoint;
      const btn = form.querySelector('button');
      btn.disabled = true;
      btn.textContent = 'Joining…';
      try {
        if (endpoint) {
          const res = await fetch(endpoint, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ email, formId: form.dataset.formid || undefined }),
          });
          if (!res.ok) throw new Error('bad status ' + res.status);
        } else {
          // Preview mode: no ESP wired yet. Persist locally so demos still work.
          await new Promise((r) => setTimeout(r, 350));
          try { localStorage.setItem('waitlist:' + email, new Date().toISOString()); } catch {}
        }
        // No email value in analytics — only the boolean (ARY-25: no PII).
        track('waitlist_submit', { placement, email_provided: true });
        form.reset();
        msg.textContent = successMsg;
        msg.style.color = '#bff0d8';
        btn.textContent = 'Joined ✓';
      } catch (err) {
        msg.textContent = 'Something went wrong — please try again or email us.';
        msg.style.color = '#ffd9a8';
        btn.disabled = false;
        btn.textContent = 'Join the waitlist';
      }
    });
  })();
</script>
