---
import { PILLARS } from '../config/content';
import Icon from './Icon.astro';
---
<section class="section" id="features">
  <div class="container">
    <div class="center" style="margin-bottom:40px;">
      <h2>One vault for everything your family owns.</h2>
      <p class="lead">Inventory, capture, and guidance — grounded in what the product does today.</p>
    </div>
    <div class="grid grid-3">
      {PILLARS.map((p) => (
        <article class="card pillar">
          <div class="pic"><Icon name={p.icon} size={24} /></div>
          <h3>{p.title}</h3>
          <p>{p.body}</p>
          <div class="proof">{p.proof}</div>
        </article>
      ))}
    </div>
  </div>
</section>
