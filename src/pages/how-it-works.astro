---
import Base from '../layouts/Base.astro';
import { BRAND } from '../config/brand';
import Eyebrow from '../components/marketing/Eyebrow.astro';
import FinalCta from '../components/marketing/FinalCta.astro';

const crumbs = [
  { name: 'Home', url: `${BRAND.url}/` },
  { name: 'How it works', url: `${BRAND.url}/how-it-works/` },
];

const steps = [
  {
    n: 1, glyph: '📸', title: 'Add what you own.',
    body: "Snap a photo or upload a document and Vaulto reads it for you — drafting the details so you're not typing everything by hand. Add a room, a receipt, or a folder of paperwork in one go.",
    detail: 'AI-assisted capture turns an overwhelming job into a few short sessions.',
  },
  {
    n: 2, glyph: '🗂️', title: 'Let Vaulto organise it.',
    body: 'Group assets into collections, add the key facts that matter, and keep the documents that prove them attached right where they belong.',
    detail: 'Property, accounts, investments, valuables, pensions — all in one structure.',
  },
  {
    n: 3, glyph: '🧭', title: 'See the whole picture.',
    body: "Your family's assets and documents in one clear view — ready to share with the people who matter, and to plan ahead with a free overview when you're ready.",
    detail: 'A clean snapshot you can hand to a solicitor or advisor.',
  },
];
---
<Base
  title="How it works"
  description="Add what you own, let Vaulto organise it, and see your whole picture in three simple steps. AI-assisted capture does the data entry for you."
  path="/how-it-works/"
  breadcrumbs={crumbs}
>
  <section class="s-hero">
    <div class="wrap">
      <Eyebrow tone="success">How it works</Eyebrow>
      <h1 class="t-display">From scattered to organised, in three steps.</h1>
      <p class="intro t-bodyL">
        You don't have to type everything by hand. Vaulto reads your photos and documents and does
        the heavy lifting — so getting started takes minutes, not weekends.
      </p>
    </div>
  </section>

  <section>
    <div class="wrap">
      <div class="steps-rows">
        {steps.map((s, i) => (
          <>
            <div class:list={['step-row', i % 2 === 1 && 'reverse']}>
              <div class="step-body">
                <div class="num" aria-hidden="true">{s.n}</div>
                <h2 class="t-title">{s.title}</h2>
                <p class="t-bodyL">{s.body}</p>
                <p class="detail">{s.detail}</p>
              </div>
              <div class="step-visual" aria-hidden="true"><span class="glyph">{s.glyph}</span></div>
            </div>
            {i < steps.length - 1 && <div class="connector" aria-hidden="true"></div>}
          </>
        ))}
      </div>
      <p class="center" style="margin-top:32px;">
        <a href="/security/" data-cta="how_security">How we keep it safe →</a>
      </p>
    </div>
  </section>

  <FinalCta title="Start your vault — free" body="Add your first few things in minutes. No spreadsheets required." ctaId="how_final" />
</Base>
