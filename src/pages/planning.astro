---
import Base from '../layouts/Base.astro';
import { BRAND } from '../config/brand';
import Eyebrow from '../components/marketing/Eyebrow.astro';
import MarketingButton from '../components/marketing/MarketingButton.astro';

const crumbs = [
  { name: 'Home', url: `${BRAND.url}/` },
  { name: 'Planning', url: `${BRAND.url}/planning/` },
];

// Advisory focus areas — channel names verified from shipped product (ARY-23 §0
// / content.ts). Primary cards per ARY-404 §4.5; calm, no-urgency taglines.
// `sensitive: true` gets softer styling — extra whitespace, zero celebration.
const areas = [
  { title: 'Will planning', tagline: 'Understand what a will should cover and where the gaps are, before you sit down with a solicitor.' },
  { title: 'Inheritance', tagline: 'See what passing things on could involve for your family — calmly, and at your own pace.', sensitive: true },
  { title: 'Financial overview', tagline: 'A clear read on your whole picture: what you own, what it means, and what to look at next.' },
  { title: 'Cross-border', tagline: 'Assets or family in more than one country? Understand the considerations that come with it.' },
  { title: 'Prenup', tagline: 'Think through protecting what matters to each of you, with clarity and no pressure.', sensitive: true },
  { title: 'Divorce & separation', tagline: 'A quiet, practical starting point for understanding assets when things are changing.', sensitive: true },
];

const moreAreas = ['Inheritance tax', 'Family-business succession', 'Insurance', 'Tax efficiency', 'Asset financing'];
---
<Base
  title="Planning"
  description="A free overview of what's at stake — inheritance, wills, cross-border, and more — then go deeper at your own pace. Informational guidance, never a replacement for your professional."
  path="/planning/"
  breadcrumbs={crumbs}
>
  <section class="s-hero">
    <div class="wrap">
      <Eyebrow tone="success">Planning &amp; advisory</Eyebrow>
      <h1 class="t-display">Be ready, before life forces it.</h1>
      <p class="intro t-bodyL">
        Start with a free overview of what's at stake. Go deeper when you're ready, at your own
        pace — and share a clean summary with the professional handling it. Guidance is
        informational; it doesn't replace your solicitor or advisor.
      </p>
    </div>
  </section>

  <section style="padding-top:8px">
    <div class="wrap">
      <div class="plan-grid">
        {areas.map((a) => (
          <div class:list={['plan-card card', a.sensitive && 'sensitive']}>
            <h3 class="t-heading">{a.title}</h3>
            <p class="tagline">{a.tagline}</p>
            <span class="pcta">Free overview → Plan when you're ready</span>
          </div>
        ))}
      </div>
      <p class="center t-body" style="margin-top:36px;">More areas you can explore</p>
      <div class="plan-chips">
        {moreAreas.map((m) => <span class="plan-chip">{m}</span>)}
      </div>
      <p class="center" style="margin-top:36px;">
        <MarketingButton href={BRAND.app} cta="planning_get_started" outbound="app">Try a free overview</MarketingButton>
      </p>
    </div>
  </section>
</Base>
