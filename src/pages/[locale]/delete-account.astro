---
/** Localized Delete-account (ARY-560). One route → every non-default locale. */
import { NON_DEFAULT_LOCALES, type Locale } from '../../config/i18n';
import DeleteAccountPage from '../../components/pages/DeleteAccountPage.astro';

export function getStaticPaths() {
  return NON_DEFAULT_LOCALES.map((locale) => ({ params: { locale } }));
}

const { locale } = Astro.params as { locale: Locale };
---
<DeleteAccountPage locale={locale} />
