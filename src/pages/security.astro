---
import Base from '../layouts/Base.astro';
import { BRAND } from '../config/brand';
import Eyebrow from '../components/marketing/Eyebrow.astro';

const crumbs = [
  { name: 'Home', url: `${BRAND.url}/` },
  { name: 'Security & Privacy', url: `${BRAND.url}/security/` },
];

const protections = [
  { ico: '🔒', title: 'Encrypted in transit.', body: 'Every connection to Vaulto uses TLS (HTTPS), so your data is encrypted as it travels between you and us.' },
  { ico: '🗄️', title: 'Encrypted at rest.', body: 'Your information and documents are stored on encrypted infrastructure — managed database and object storage.' },
  { ico: '🔑', title: 'Passwords never stored plainly.', body: "We hash your password with a strong, modern algorithm (scrypt) — even we can't read it." },
  { ico: '⏳', title: 'Short-lived sessions.', body: 'Sign-in tokens are short-lived and kept in memory; the token that keeps you signed in lives in a secure, script-proof cookie.' },
  { ico: '🚦', title: 'Protected against abuse.', body: 'We rate-limit sign-in and other sensitive actions to defend against automated attacks.' },
  { ico: '👤', title: 'Access controls.', body: 'You can only see and edit your own vault. Our systems enforce this on every request.' },
];

const promises = [
  { big: '🚫', title: 'We never sell your data.', body: 'Full stop.' },
  { big: '🤝', title: "We don't share to advertise.", body: "Your information isn't handed to third parties to market to you." },
  { big: '🎛️', title: "You're in control.", body: 'You decide what you add — and what you remove.' },
];
---
<Base
  title="Security & Privacy"
  description="How Vaulto protects your family's information — encryption in transit and at rest, hashed passwords, strict access control. Plain language, no overclaim."
  path="/security/"
  breadcrumbs={crumbs}
>
  <section class="s-hero">
    <div class="wrap">
      <Eyebrow tone="info">🛡️ Security &amp; privacy</Eyebrow>
      <h1 class="t-display">Your family's information, protected.</h1>
      <p class="intro t-bodyL">
        Vaulto holds sensitive details — what you own, where it is, the documents that prove it.
        We treat that responsibility seriously. Here's exactly how we protect it, in plain language.
      </p>
    </div>
  </section>

  <section>
    <div class="wrap">
      <div class="sec-head"><h2 class="t-title">How we protect your data</h2></div>
      <div class="grid-3">
        {protections.map((p) => (
          <div class="pcard card">
            <div class="ico" aria-hidden="true">{p.ico}</div>
            <h3 class="t-heading">{p.title}</h3>
            <p class="t-body">{p.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <div class="promise callout">
    <div class="wrap" style="display:block;">
      <h2 class="t-title">Our privacy promises</h2>
      <div class="promise-grid">
        {promises.map((p) => (
          <div class="promise-item">
            <div class="big" aria-hidden="true">{p.big}</div>
            <h3 class="t-heading">{p.title}</h3>
            <p class="t-body">{p.body}</p>
          </div>
        ))}
      </div>
    </div>
  </div>

  <section>
    <div class="wrap">
      <div class="sec-head"><h2 class="t-title">Your data is yours</h2></div>
      <p class="t-body" style="max-width:680px;margin:0 auto;text-align:center;">
        Your data is yours — export everything (your data + your original files) at any time.
        From Settings, <b>Download everything (.zip)</b> gives you one file with a complete,
        machine-readable copy of your records plus every original photo and scan you uploaded.
        No lock-in, no waiting on us. The machine-readable export also satisfies your right to
        data portability under GDPR (Article&nbsp;20).
      </p>
    </div>
  </section>

  <section>
    <div class="wrap">
      <p class="honesty">
        <b>Plain-language, no overclaim.</b> We describe only what's true today: encryption in
        transit and at rest, hashed passwords, strict access control. We deliberately do
        <b>not</b> claim "zero-knowledge," "bank-level," or any certification we haven't earned.
        Data export is live (above). When we add app-layer encryption or a formal third-party
        audit, this page will say so.
        For privacy or security questions, contact
        <a href={`mailto:${BRAND.email.privacy}`}>{BRAND.email.privacy}</a>.
      </p>
    </div>
  </section>
</Base>
